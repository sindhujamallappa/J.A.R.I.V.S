# Optional environment overrides for J.A.R.I.V.S.
# Copy to .env and uncomment any you want to override at runtime.
# These take precedence over config/config.yaml. No secrets belong here.

# JARVIS_LOG_LEVEL=DEBUG
# JARVIS_LOG_FILE=logs/jarvis.log
# JARVIS_WAKE_MODEL=hey_jarvis
# JARVIS_WAKE_THRESHOLD=0.5
# JARVIS_INTENT_HOST=http://localhost:11434
# JARVIS_INTENT_MODEL=llama3.2:3b
# JARVIS_AUDIO_INPUT_DEVICE=          # int index or mic name substring
